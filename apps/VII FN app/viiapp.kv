WindowManager:
    MainWindow:
    ShopWindow:
    StatsWindow:
    MapWindow:

#:set font 'fortnite.ttf'

<MainWindow>:
    canvas.before:
        Color:
            rgba: 0.4, 0.38, 0.94, 1
        Rectangle:
            pos: self.pos
            size: self.size
    name: 'main'
    GridLayout:
        rows: 2
        BoxLayout:
            orientation: 'vertical'
            Image:
                source: 'VIIBot logo.png'
            Label:
                text: 'VII Fortnite App'
                font_name: font
                font_size: 60
        BoxLayout:
            orientation: 'vertical'
            Button:
                text: 'Shop'
                font_name: font 
                font_size: 60
                on_release:
                    app.root.current = 'shop'
                    root.manager.transition.direction = 'left'
            Button:
                text: 'Stats'
                font_name: font 
                font_size: 60
                on_release:
                    app.root.current = 'stats'
                    root.manager.transition.direction = 'left'
            Button:
                text: 'Map'
                font_name: font 
                font_size: 60
                on_release:
                    app.root.current = 'map'
                    root.manager.transition.direction = 'left'

<ShopWindow>:
    canvas.before:
        Color:
            rgba: 0.4, 0.38, 0.94, 1
        Rectangle:
            pos: self.pos
            size: self.size
    name: 'shop'
    FloatLayout:
        StencilView:
            id: stencil
            size_hint: 1, 0.95
            pos_hint: {'left': 1, 'top': 1}
            ScatterLayout:
                pos: stencil.pos
                size: shop_image.size
                do_rotation: False
                Image:
                    id: shop_image
                    source: 'FortniteShop.png'
                    size_hint_y: None
                    size_hint_x: None
                    width: stencil.width
                    height: stencil.width/self.image_ratio
                    center: self.parent.center
                    allow_stretch: False
                    keep_ratio: True
        # Image:
        #     source: 'FortniteShop.png'
        Button:
            text: 'Go back'
            font_name: font
            font_size: 35
            size_hint: (1, 0.05)
            pos_hint: {'left': 0, 'bottom': 0}
            on_release:
                app.root.current = 'main'
                root.manager.transition.direction = 'right'

<StatsWindow>:
    canvas.before:
        Color:
            rgba: 0.4, 0.38, 0.94, 1
        Rectangle:
            pos: self.pos
            size: self.size
    name: 'stats'
    GridLayout:
        rows: 2
        Label:
            text: 'stats text'
            font_name: font
        Button:
            text: 'Go back'
            font_name: font
            font_size: 60
            on_release:
                app.root.current = 'main'
                root.manager.transition.direction = 'right'

<MapWindow>:
    canvas.before:
        Color:
            rgba: 0.4, 0.38, 0.94, 1
        Rectangle:
            pos: self.pos
            size: self.size
    name: 'map'
    GridLayout:
        rows: 2
        Label:
            text: 'map image'
            font_name: font
        Button:
            text: 'Go back'
            font_name: font
            font_size: 60
            on_release:
                app.root.current = 'main'
                root.manager.transition.direction = 'right'